<?xml version="1.0" encoding="utf-8"?>
<!--
    shape_btn_yellow.xml
    Used for the main "Sign In" button.

    Figma spec:
      - cornerRadius: 40dp (pill shape)
      - fill: #FBFB64 (solid yellow, full opacity)
      - stroke: #BCBC19, width 1dp
      - Drop shadow: replicated via elevation on the Button itself (android:elevation="4dp")
        or via a layer-list if a programmatic shadow is needed; CardView elevation is simpler.

    Pressed state darkens the fill slightly for tactile feedback.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed state: slightly darker yellow for feedback -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="40dp" />
            <solid android:color="#D4D400" />
            <stroke android:width="1dp" android:color="#BCBC19" />
        </shape>
    </item>

    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="40dp" />
            <solid android:color="#FBFB64" />
            <stroke android:width="1dp" android:color="#BCBC19" />
        </shape>
    </item>

</selector>