<?xml version="1.0" encoding="utf-8"?>
<!--
    shape_input_field.xml
    Used for Username and Password input containers.

    Figma spec:
      - cornerRadius: 40dp (fully pill-like on a 43px tall field)
      - fill: #FBFB64 at 16% opacity  →  hex #28FBFB64 (0x28 ≈ 16%)
        Note: the password field uses #F8F847@16% — visually identical, using unified color
      - stroke: #BCBC19, width 1dp
      - No shadow on inputs (shadow is only on the Sign In button & social buttons)
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <corners android:radius="40dp" />

    <solid android:color="#28FBFB64" />

    <stroke
        android:width="1dp"
        android:color="#BCBC19" />

</shape>