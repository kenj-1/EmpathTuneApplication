<?xml version="1.0" encoding="utf-8"?>
<!--
    Dashboard Page
    Converted from FigML: frame id="13:3" name="Dashboard_Page"
    Original size: 402 x 874 dp
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_bg">

    <!-- =============================================
         LAYER 1: Decorative background ellipses
         Ellipse id="2:33"  → top-left  (partially off-screen)
         Ellipse id="33:80" → top-right (partially off-screen)
         ============================================= -->
    <View
        android:id="@+id/ellipse_top_left"
        android:layout_width="@dimen/ellipse_bg_size"
        android:layout_height="@dimen/ellipse_bg_size"
        android:layout_gravity="top|start"
        android:layout_marginStart="@dimen/ellipse_left_margin_start"
        android:layout_marginTop="@dimen/ellipse_left_margin_top"
        android:background="@drawable/shape_circle_yellow" />

    <View
        android:id="@+id/ellipse_top_right"
        android:layout_width="@dimen/ellipse_bg_size"
        android:layout_height="@dimen/ellipse_bg_size"
        android:layout_gravity="top|end"
        android:layout_marginEnd="@dimen/ellipse_right_margin_end"
        android:layout_marginTop="@dimen/ellipse_right_margin_top"
        android:background="@drawable/shape_circle_yellow" />

    <!-- =============================================
         LAYER 2: Bottom gradient board
         Vector id="33:32" name="LogInBoard"
         y=290, height=603 → fills lower ~69% of screen
         ============================================= -->
    <View
        android:id="@+id/view_login_board"
        android:layout_width="match_parent"
        android:layout_height="@dimen/board_height"
        android:layout_gravity="bottom"
        android:background="@drawable/shape_gradient_board" />

    <!-- =============================================
         LAYER 3: Main vertical content
         ============================================= -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:clipToPadding="false">

        <!-- ── GREETING TEXT ──────────────────────
             Text id="33:48"
             "How are we feeling today, user?"
             x=68, y=73, fontSize=19, fontWeight=300
             ────────────────────────────────────── -->
        <TextView
            android:id="@+id/tv_greeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/greeting_margin_top"
            android:text="@string/greeting_text"
            android:textSize="@dimen/greeting_text_size"
            android:textColor="@color/text_black"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:letterSpacing="0.2"
            android:paddingStart="@dimen/greeting_padding_horizontal"
            android:paddingEnd="@dimen/greeting_padding_horizontal" />

        <!-- ── AUTO PLAYER (circular play button) ──
             Group id="33:44" name="AutoPlayer"
             x=144, y=141, size=115x115
             ──────────────────────────────────────── -->
        <FrameLayout
            android:id="@+id/fl_auto_player"
            android:layout_width="@dimen/player_circle_size"
            android:layout_height="@dimen/player_circle_size"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/player_margin_top">

            <!-- Outer yellow circle (Ellipse_9) -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/shape_circle_yellow_outer" />

            <!-- Inner white circle + play icon (Ellipse_10 + PlayButton) -->
            <ImageView
                android:id="@+id/iv_play_button"
                android:layout_width="@dimen/player_inner_size"
                android:layout_height="@dimen/player_inner_size"
                android:layout_gravity="center"
                android:background="@drawable/shape_circle_white"
                android:src="@drawable/ic_play"
                android:scaleType="center"
                android:padding="@dimen/play_icon_padding"
                android:contentDescription="@string/cd_play_button" />
        </FrameLayout>

        <!-- ── FEELING INPUT BOX ──────────────────
             Rectangle id="34:82" name="Rectangle_8"
             x=28, y=385, width=345, height=103, cornerRadius=20
             ────────────────────────────────────── -->
        <EditText
            android:id="@+id/et_feelings"
            android:layout_width="@dimen/input_box_width"
            android:layout_height="@dimen/input_box_height"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/input_margin_top"
            android:background="@drawable/shape_input_background"
            android:hint="@string/hint_feelings"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_black"
            android:textSize="@dimen/input_text_size"
            android:fontFamily="sans-serif-light"
            android:paddingStart="@dimen/input_padding_horizontal"
            android:paddingEnd="@dimen/input_padding_horizontal"
            android:paddingTop="@dimen/input_padding_vertical"
            android:gravity="top|start"
            android:inputType="textMultiLine"
            android:maxLines="4" />

        <!-- ── SONG PLAYER CARD ───────────────────
             Group id="33:54" name="SongPlayer"
             x=123, y=498, width=170, height=275
             ──────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/ll_song_player"
            android:layout_width="@dimen/song_player_width"
            android:layout_height="@dimen/song_player_height"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/song_player_margin_top"
            android:orientation="vertical"
            android:background="@drawable/shape_song_player_bg"
            android:gravity="center_horizontal"
            android:paddingTop="@dimen/song_player_padding_top"
            android:paddingBottom="@dimen/song_player_padding_bottom"
            android:paddingStart="@dimen/song_player_padding_horizontal"
            android:paddingEnd="@dimen/song_player_padding_horizontal">

            <!-- Album art (image_10, BleederEffect blur overlay) -->
            <FrameLayout
                android:layout_width="@dimen/album_art_size"
                android:layout_height="@dimen/album_art_size">

                <!-- Blur / dark overlay (BleederEffect id="33:58") -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/shape_blur_overlay" />

                <!-- Album art image (image_10 id="33:51") -->
                <ImageView
                    android:id="@+id/iv_album_art"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_album_placeholder"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/cd_album_art" />
            </FrameLayout>

            <!-- Song title (Text id="33:68" name="Less_Than_Zero") -->
            <TextView
                android:id="@+id/tv_song_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/song_title_margin_top"
                android:text="@string/song_title"
                android:textSize="@dimen/song_title_text_size"
                android:textColor="@color/text_black"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.2"
                android:gravity="center" />

            <!-- Playback controls row (Group id="33:70" name="Group_18") -->
            <LinearLayout
                android:id="@+id/ll_controls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/controls_margin_top"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- Skip back (image_12 id="33:60") -->
                <ImageView
                    android:id="@+id/iv_skip_back"
                    android:layout_width="@dimen/control_icon_size"
                    android:layout_height="@dimen/control_icon_size"
                    android:src="@drawable/ic_skip_back"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/cd_skip_back" />

                <!-- Play/Pause center (image_14 id="33:66") -->
                <ImageView
                    android:id="@+id/iv_play_pause"
                    android:layout_width="@dimen/control_play_size"
                    android:layout_height="@dimen/control_play_size"
                    android:layout_marginStart="@dimen/control_spacing"
                    android:layout_marginEnd="@dimen/control_spacing"
                    android:src="@drawable/ic_play"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/cd_play_pause" />

                <!-- Skip forward (image_11 id="33:56") -->
                <ImageView
                    android:id="@+id/iv_skip_forward"
                    android:layout_width="@dimen/control_icon_size"
                    android:layout_height="@dimen/control_icon_size"
                    android:src="@drawable/ic_skip_forward"
                    android:scaleType="fitCenter"
                    android:contentDescription="@string/cd_skip_forward" />
            </LinearLayout>

            <!-- Progress bar (Rectangle_7 id="33:71")
                 White semi-transparent bar, opacity=0.8 -->
            <SeekBar
                android:id="@+id/seekbar_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/seekbar_margin_top"
                android:progressDrawable="@drawable/shape_seekbar_track"
                android:thumb="@null"
                android:max="100"
                android:progress="0" />

            <!-- Time indicators row (image_15 + image_16) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/time_row_margin_top"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/iv_time_start"
                    android:layout_width="@dimen/time_icon_size"
                    android:layout_height="@dimen/time_icon_size"
                    android:src="@drawable/ic_time_indicator"
                    android:contentDescription="@string/cd_time_start" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/iv_time_end"
                    android:layout_width="@dimen/time_icon_size"
                    android:layout_height="@dimen/time_icon_size"
                    android:src="@drawable/ic_time_indicator"
                    android:contentDescription="@string/cd_time_end" />
            </LinearLayout>

        </LinearLayout>

        <!-- Spacer to push bottom nav to the bottom -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- ── BOTTOM NAVIGATION BAR ──────────────
             Rectangle id="33:34" name="Rectangle_6"
             y=788, width=402, height=74, cornerRadius=30
             ────────────────────────────────────── -->
        <FrameLayout
            android:id="@+id/fl_bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="@dimen/bottom_nav_height"
            android:background="@drawable/shape_bottom_nav">

            <!-- Nav icon (image_9 id="33:46") x=312, y=801, size=51 -->
            <ImageView
                android:id="@+id/iv_nav_icon"
                android:layout_width="@dimen/nav_icon_size"
                android:layout_height="@dimen/nav_icon_size"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="@dimen/nav_icon_margin_end"
                android:src="@drawable/ic_nav_icon"
                android:scaleType="fitCenter"
                android:contentDescription="@string/cd_nav_icon" />
        </FrameLayout>

    </LinearLayout>
</FrameLayout>
