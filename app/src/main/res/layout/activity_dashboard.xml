<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_dashboard.xml  —  Full Figma Sync Pass
    Target  : Small Phone API 36 (360 × 640 dp)
    Root    : LinearLayout  (vertical, full-screen)
    Allowed : LinearLayout · RelativeLayout · CardView (structural only)
    ───────────────────────────────────────────────────────────────────
    ALL IDs PRESERVED (DashboardActivity / DashboardPresenter bindings):
      tv_greeting · et_feelings · fl_auto_player · iv_play_button
      chip_happy · chip_love · chip_sad
      card_gym_mood · iv_gym_art · iv_play_gym
      card_study_mood · iv_study_art · iv_play_study
      ll_song_player · tv_song_title · iv_album_art
      ll_controls · seekbar_progress · seekbar_volume
      iv_shuffle · iv_skip_back · iv_play_pause · iv_skip_forward · iv_repeat
      fl_bottom_nav · tv_logout · iv_home · iv_nav_icon
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- ═══════════════════════════════════════════════════════════
         SCROLLABLE BODY
         layout_weight="1" ensures the bottom nav is always anchored
         at the very bottom regardless of content height.
         ═══════════════════════════════════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ─────────────────────────────────────────────────────
                 HEADER  —  white section
                 RelativeLayout is the minimum wrapper needed here to
                 allow the two large yellow circles to overlap the
                 greeting and input box.  clipChildren + clipToPadding
                 are disabled so circles bleed off-screen naturally.
                 ───────────────────────────────────────────────────── -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:minHeight="220dp">

                <!-- ── Decorative circle: top-RIGHT (Figma Ellipse_11)
                     x=177, y=-153, 244dp diameter
                     Sits at end/top, pushed right and up off-screen  -->
                <View
                    android:layout_width="230dp"
                    android:layout_height="230dp"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentTop="true"
                    android:translationX="62dp"
                    android:translationY="-105dp"
                    android:background="@drawable/shape_circle_yellow" />

                <!-- ── Decorative circle: top-LEFT (Figma Ellipse_12)
                     x=-84, y=-232, 244dp diameter
                     Sits at start/top, pushed left and up off-screen  -->
                <View
                    android:layout_width="230dp"
                    android:layout_height="230dp"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentTop="true"
                    android:translationX="-72dp"
                    android:translationY="-160dp"
                    android:background="@drawable/shape_circle_yellow" />

                <!-- ── Greeting text (Figma: 19sp, light, centered, y≈57)
                     Presenter calls showGreeting() which updates this at
                     runtime — the static text is just a render placeholder -->
                <TextView
                    android:id="@+id/tv_greeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="44dp"
                    android:fontFamily="sans-serif-light"
                    android:gravity="center"
                    android:letterSpacing="0.05"
                    android:text="How are we feeling\ntoday, user?"
                    android:textColor="#000000"
                    android:textSize="19sp" />

                <!-- ── Feelings prompt input (Figma: #D9D9D9, inner shadow,
                     cornerRadius 20dp, y≈167, h≈72dp)                    -->
                <EditText
                    android:id="@+id/et_feelings"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:layout_below="@id/tv_greeting"
                    android:layout_marginTop="18dp"
                    android:layout_marginStart="18dp"
                    android:layout_marginEnd="18dp"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/shape_input_background"
                    android:fontFamily="sans-serif-light"
                    android:gravity="top|start"
                    android:hint="Type what you feel here..."
                    android:inputType="textMultiLine"
                    android:maxLines="3"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:textColor="#000000"
                    android:textColorHint="#80000000"
                    android:textSize="8sp" />

                <!-- Anchor — ensures RelativeLayout wraps to below the input -->
                <View
                    android:id="@+id/header_bottom_anchor"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_below="@id/et_feelings" />

            </RelativeLayout>

            <!-- ─────────────────────────────────────────────────────
                 GRADIENT CONTENT AREA
                 Figma: gradientStops #EDDA0A → #BBBBBB (top → bottom)
                 shape_gradient_board uses angle=270 which is top→bottom
                 in Android (startColor=yellow at top, endColor=gray at bottom)
                 ───────────────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/shape_gradient_board"
                android:paddingTop="10dp"
                android:paddingBottom="18dp">

                <!-- ── AutoPlayer: yellow outer circle + white inner + play icon
                     Figma: Ellipse_9 (68dp yellow), Ellipse_10 (68dp white)  -->
                <FrameLayout
                    android:id="@+id/fl_auto_player"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="8dp">

                    <!-- Outer yellow circle -->
                    <View
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/shape_circle_yellow_outer" />

                    <!-- Inner white circle + play icon -->
                    <ImageView
                        android:id="@+id/iv_play_button"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_gravity="center"
                        android:background="@drawable/shape_circle_white"
                        android:contentDescription="Auto play"
                        android:padding="10dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_play" />

                </FrameLayout>

                <!-- ── Separator line (Figma: Line_1 - thin gray horizontal) -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_marginBottom="6dp"
                    android:background="#80808080" />

                <!-- ── "How do you want to listen, user? We are open ears....."
                     Figma: 10sp, centered, y≈344                             -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-light"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="6dp"
                    android:text="How do you want to listen, user? We are open ears....."
                    android:textColor="#000000"
                    android:textSize="8sp" />

                <!-- ── "Are we feeling......." (Figma: 10sp, left-aligned, y≈384) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-light"
                    android:paddingStart="14dp"
                    android:layout_marginBottom="6dp"
                    android:text="Are we feeling......."
                    android:textColor="#000000"
                    android:textSize="8sp" />

                <!-- ── Mood chips: Happy | Love | Sad
                     Figma: y≈417, h≈36dp yellow pills with emoji icons
                     Each chip has equal width via layout_weight="1"          -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginBottom="6dp">

                    <!-- Happy chip -->
                    <LinearLayout
                        android:id="@+id/chip_happy"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:background="@drawable/shape_btn_yellow"
                        android:gravity="center"
                        android:layout_marginEnd="5dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:elevation="3dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-light"
                            android:text="Happy"
                            android:textColor="#000000"
                            android:textSize="8sp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginStart="4dp"
                            android:contentDescription="Happy"
                            android:src="@drawable/happy" />

                    </LinearLayout>

                    <!-- Love chip -->
                    <LinearLayout
                        android:id="@+id/chip_love"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:background="@drawable/shape_btn_yellow"
                        android:gravity="center"
                        android:layout_marginStart="5dp"
                        android:layout_marginEnd="5dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:elevation="3dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-light"
                            android:text="Love"
                            android:textColor="#000000"
                            android:textSize="8sp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginStart="4dp"
                            android:contentDescription="Love"
                            android:src="@drawable/heart" />

                    </LinearLayout>

                    <!-- Sad chip -->
                    <LinearLayout
                        android:id="@+id/chip_sad"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:background="@drawable/shape_btn_yellow"
                        android:gravity="center"
                        android:layout_marginStart="5dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:elevation="3dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-light"
                            android:text="Sad"
                            android:textColor="#000000"
                            android:textSize="8sp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginStart="4dp"
                            android:contentDescription="Sad"
                            android:src="@drawable/sad" />

                    </LinearLayout>

                </LinearLayout>

                <!-- ── "What mood are we feeling today?" (Figma: 10sp, left, y≈467) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-light"
                    android:paddingStart="14dp"
                    android:layout_marginBottom="8dp"
                    android:text="What mood are we feeling today?"
                    android:textColor="#000000"
                    android:textSize="8sp" />

                <!-- ── Playlist cards: Gym Mood | Study Mood
                     Figma: y≈490, h≈122dp, cornerRadius 30dp, gradient bg  -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="12dp">

                    <!-- Gym Mood card -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_gym_mood"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="7dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="5dp"
                        app:cardBackgroundColor="#EDDA0A">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <!-- Album art fills card -->
                            <ImageView
                                android:id="@+id/iv_gym_art"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="Gym Mood album art"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_album_placeholder" />

                            <!-- "Gym Mood" label — top-center -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerHorizontal="true"
                                android:layout_marginTop="7dp"
                                android:fontFamily="sans-serif-light"
                                android:text="Gym Mood"
                                android:textColor="#000000"
                                android:textSize="7sp" />

                            <!-- Play circle — bottom-right -->
                            <FrameLayout
                                android:id="@+id/iv_play_gym"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:layout_alignParentBottom="true"
                                android:layout_alignParentEnd="true"
                                android:layout_margin="7dp"
                                android:clickable="true"
                                android:focusable="true">

                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@drawable/shape_circle_yellow_outer" />

                                <ImageView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:background="@drawable/shape_circle_white"
                                    android:contentDescription="Play gym mood"
                                    android:padding="5dp"
                                    android:scaleType="fitCenter"
                                    android:src="@drawable/ic_play" />

                            </FrameLayout>

                        </RelativeLayout>

                    </androidx.cardview.widget.CardView>

                    <!-- Study Mood card -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_study_mood"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginStart="7dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="5dp"
                        app:cardBackgroundColor="#EDDA0A">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/iv_study_art"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="Study Mood album art"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_album_placeholder" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerHorizontal="true"
                                android:layout_marginTop="7dp"
                                android:fontFamily="sans-serif-light"
                                android:text="Study Mood"
                                android:textColor="#000000"
                                android:textSize="7sp" />

                            <FrameLayout
                                android:id="@+id/iv_play_study"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:layout_alignParentBottom="true"
                                android:layout_alignParentEnd="true"
                                android:layout_margin="7dp"
                                android:clickable="true"
                                android:focusable="true">

                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@drawable/shape_circle_yellow_outer" />

                                <ImageView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:background="@drawable/shape_circle_white"
                                    android:contentDescription="Play study mood"
                                    android:padding="5dp"
                                    android:scaleType="fitCenter"
                                    android:src="@drawable/ic_play" />

                            </FrameLayout>

                        </RelativeLayout>

                    </androidx.cardview.widget.CardView>

                </LinearLayout>

                <!-- ── Song Player Card
                     Figma: SongPlayer y≈638, h≈107dp, #BBBBBB fill, 30dp radius
                     ID: ll_song_player — preserved for DashboardActivity binding -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/ll_song_player"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="5dp"
                    app:cardBackgroundColor="#BBBBBB">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp">

                        <!-- "You're in love...." — yellow pill tag, centered -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginBottom="8dp"
                            android:background="@drawable/shape_btn_yellow"
                            android:fontFamily="sans-serif-light"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"
                            android:text="You're in love...."
                            android:textColor="#000000"
                            android:textSize="6sp" />

                        <!-- Song detail row: left (info+controls) | right (album art) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <!-- LEFT COLUMN — song info, seekbar, controls, volume -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <!-- Song title (Figma: "Naiilang", 8sp, bold) -->
                                <TextView
                                    android:id="@+id/tv_song_title"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:letterSpacing="0.10"
                                    android:text="Naiilang"
                                    android:textColor="#000000"
                                    android:textSize="8sp"
                                    android:textStyle="bold" />

                                <!-- Artist name (Figma: "Le John", 6sp, 35% opacity) -->
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="sans-serif-light"
                                    android:letterSpacing="0.10"
                                    android:text="Le John"
                                    android:textColor="#59000000"
                                    android:textSize="6sp" />

                                <!-- Album name (Figma: "Naiilang", 6sp, 35% opacity) -->
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="6dp"
                                    android:fontFamily="sans-serif-light"
                                    android:letterSpacing="0.10"
                                    android:text="Naiilang"
                                    android:textColor="#59000000"
                                    android:textSize="6sp" />

                                <!-- Progress seekbar (Figma: Rectangle_8, white, 84% filled) -->
                                <SeekBar
                                    android:id="@+id/seekbar_progress"
                                    android:layout_width="match_parent"
                                    android:layout_height="6dp"
                                    android:max="100"
                                    android:progress="84"
                                    android:progressDrawable="@drawable/shape_seekbar_track"
                                    android:thumb="@null" />

                                <!-- Time indicators: 0:00 .............. 4:07 -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:layout_marginTop="2dp"
                                    android:layout_marginBottom="5dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="sans-serif-light"
                                        android:text="0:00"
                                        android:textColor="#59000000"
                                        android:textSize="5sp" />

                                    <View
                                        android:layout_width="0dp"
                                        android:layout_height="1dp"
                                        android:layout_weight="1" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="sans-serif-light"
                                        android:text="4:07"
                                        android:textColor="#59000000"
                                        android:textSize="5sp" />

                                </LinearLayout>

                                <!-- Playback controls (Figma: shuffle|prev|play|next|repeat) -->
                                <LinearLayout
                                    android:id="@+id/ll_controls"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="5dp"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">

                                    <ImageView
                                        android:id="@+id/iv_shuffle"
                                        android:layout_width="13dp"
                                        android:layout_height="13dp"
                                        android:contentDescription="Shuffle"
                                        android:scaleType="fitCenter"
                                        android:src="@drawable/shuffle" />

                                    <ImageView
                                        android:id="@+id/iv_skip_back"
                                        android:layout_width="13dp"
                                        android:layout_height="13dp"
                                        android:layout_marginStart="9dp"
                                        android:contentDescription="Previous"
                                        android:scaleType="fitCenter"
                                        android:src="@drawable/ic_skip_back" />

                                    <ImageView
                                        android:id="@+id/iv_play_pause"
                                        android:layout_width="18dp"
                                        android:layout_height="18dp"
                                        android:layout_marginStart="9dp"
                                        android:contentDescription="Play / Pause"
                                        android:scaleType="fitCenter"
                                        android:src="@drawable/ic_play" />

                                    <ImageView
                                        android:id="@+id/iv_skip_forward"
                                        android:layout_width="13dp"
                                        android:layout_height="13dp"
                                        android:layout_marginStart="9dp"
                                        android:contentDescription="Next"
                                        android:scaleType="fitCenter"
                                        android:src="@drawable/ic_skip_forward" />

                                    <ImageView
                                        android:id="@+id/iv_repeat"
                                        android:layout_width="13dp"
                                        android:layout_height="13dp"
                                        android:layout_marginStart="9dp"
                                        android:contentDescription="Repeat"
                                        android:scaleType="fitCenter"
                                        android:src="@drawable/repeat" />

                                </LinearLayout>

                                <!-- Volume row: vol-low | seekbar | vol-high -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">

                                    <ImageView
                                        android:layout_width="9dp"
                                        android:layout_height="9dp"
                                        android:contentDescription="Volume low"
                                        android:scaleType="fitCenter"
                                        android:src="@drawable/volumelow" />

                                    <SeekBar
                                        android:id="@+id/seekbar_volume"
                                        android:layout_width="0dp"
                                        android:layout_height="6dp"
                                        android:layout_weight="1"
                                        android:layout_marginStart="4dp"
                                        android:layout_marginEnd="4dp"
                                        android:max="100"
                                        android:progress="60"
                                        android:progressDrawable="@drawable/shape_seekbar_track"
                                        android:thumb="@null" />

                                    <ImageView
                                        android:layout_width="9dp"
                                        android:layout_height="9dp"
                                        android:contentDescription="Volume high"
                                        android:scaleType="fitCenter"
                                        android:src="@drawable/volumehigh" />

                                </LinearLayout>

                            </LinearLayout>

                            <!-- RIGHT COLUMN — album art (Figma: image_22, ~70×70dp) -->
                            <ImageView
                                android:id="@+id/iv_album_art"
                                android:layout_width="70dp"
                                android:layout_height="70dp"
                                android:layout_marginStart="12dp"
                                android:contentDescription="Album art"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_album_placeholder" />

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>
            <!-- end gradient content LinearLayout -->

        </LinearLayout>
        <!-- end scroll child LinearLayout -->

    </ScrollView>
    <!-- end ScrollView -->

    <!-- ═══════════════════════════════════════════════════════════
         BOTTOM NAVIGATION BAR  —  always anchored at screen bottom
         Figma: HomeNavigation — #E9EE67 background, 3 slots,
         center slot has a raised #F0F0F0 white circle (Ellipse_18).

         IDs from DashboardActivity.kt — MUST NOT CHANGE:
           tv_logout   → left slot (click = logout via Presenter)
           iv_nav_icon → right slot (click = navigate to Profile)
         ═══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/fl_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:orientation="horizontal"
        android:background="@drawable/shape_bottom_nav"
        android:gravity="center_vertical">

        <!-- LEFT SLOT: create icon
             tv_logout ID preserved — DashboardActivity binds logout here.
             drawableTop makes it look like an icon button despite being TextView -->
        <ImageView
            android:id="@+id/tv_logout"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="15dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_nav_create"
            android:contentDescription="Logout" />

        <!-- CENTER SLOT: Home icon on raised white circle -->
        <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <!-- Raised white circle (Figma: Ellipse_18, 63dp, yellow-glow shadow) -->
            <View
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_centerInParent="true"
                android:background="@drawable/shape_circle_white_nav"
                android:elevation="4dp" />

            <!-- Home icon on top of the white circle -->
            <ImageView
                android:id="@+id/iv_home"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_centerInParent="true"
                android:contentDescription="Home"
                android:elevation="5dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_home" />

        </RelativeLayout>

        <!-- RIGHT SLOT: Profile icon
             iv_nav_icon preserved — DashboardActivity binds navigateToProfile() -->
        <ImageView
            android:id="@+id/iv_nav_icon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Profile"
            android:focusable="true"
            android:padding="15dp"
            android:scaleType="fitCenter"
            android:src="@drawable/username" />

    </LinearLayout>
    <!-- end bottom nav -->

</LinearLayout>