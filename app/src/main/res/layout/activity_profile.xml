<?xml version="1.0" encoding="utf-8"?>
<!--
    Profile Page
    Converted from FigML: frame id="13:5" name="Profile_Page"
    Original size: 402 × 874 dp
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/profile_bg">

    <!-- =============================================
         LAYER 1: Background gradient board
         Vector id="36:3" name="LogInBoard"
         x=9, y=234, width=383, height=634, cornerRadius=30
         Gradient: #bbbbbb → #edda0a → #edda0a → #bbbbbb
         ============================================= -->
    <View
        android:id="@+id/view_profile_board"
        android:layout_width="@dimen/profile_board_width"
        android:layout_height="@dimen/profile_board_height"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="100dp"
        android:background="@drawable/shape_profile_board" />

    <!-- =============================================
         LAYER 2: Main vertical content (LinearLayout)
         ============================================= -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ── TOP HEADER ROW ──────────────────────
             Contains: profile image (left), name + status
             (center-right), menu icon (far right)
             ──────────────────────────────────────── -->
        <FrameLayout
            android:id="@+id/fl_header"
            android:layout_width="match_parent"
            android:layout_height="@dimen/profile_header_height">

            <!-- Menu / hamburger icon (Group_19)
                 x=335, y=17, size=47 → top-right -->
            <ImageView
                android:id="@+id/iv_menu"
                android:layout_width="@dimen/menu_icon_size"
                android:layout_height="@dimen/menu_icon_size"
                android:layout_gravity="top|end"
                android:layout_marginTop="@dimen/menu_margin_top"
                android:layout_marginEnd="@dimen/menu_margin_end"
                android:src="@drawable/ic_profile_menu"
                android:background="@drawable/shape_menu_bg"
                android:scaleType="center"
                android:padding="@dimen/menu_icon_padding"
                android:contentDescription="@string/cd_menu" />

            <!-- Profile image (image_9 id="36:5")
                 x=27, y=97, width=123, height=123 -->
            <ImageView
                android:id="@+id/iv_profile_photo"
                android:layout_width="@dimen/profile_photo_size"
                android:layout_height="@dimen/profile_photo_size"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="@dimen/profile_photo_margin_start"
                android:layout_marginBottom="@dimen/profile_photo_margin_bottom"
                android:src="@drawable/ic_profile_placeholder"
                android:scaleType="centerCrop"
                android:contentDescription="@string/cd_profile_photo" />

            <!-- Name + Status column (right of photo)
                 "User" (id="36:8") x=167, y=127, fontSize=32
                 "Empathy Status: Yearner" (id="36:7") x=170, y=182, fontSize=12 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="@dimen/profile_name_margin_start"
                android:layout_marginBottom="@dimen/profile_name_margin_bottom">

                <TextView
                    android:id="@+id/tv_username_display"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_username_display"
                    android:textSize="@dimen/profile_name_text_size"
                    android:textColor="@color/text_black"
                    android:fontFamily="sans-serif-light"
                    android:letterSpacing="0.2" />

                <TextView
                    android:id="@+id/tv_empathy_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/status_margin_top"
                    android:text="@string/empathy_status"
                    android:textSize="@dimen/status_text_size"
                    android:textColor="@color/text_black"
                    android:fontFamily="sans-serif-light"
                    android:letterSpacing="0.2" />
            </LinearLayout>
        </FrameLayout>

        <!-- ── SCROLLABLE FORM SECTION ─────────────
             Contains all 5 labelled input fields
             wrapped in ScrollView so content is
             accessible on smaller screens
             ──────────────────────────────────────── -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="@dimen/form_padding_bottom">

                <!-- ── FIELD 1: Username ─────────────
                     Label id="38:37" y=343, fontWeight=800
                     Field id="38:12" y=360, text="User"
                     ─────────────────────────────────── -->
                <TextView
                    android:id="@+id/tv_label_username"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/field_label_margin_top_first"
                    android:alpha="0.75"
                    android:letterSpacing="0.2"
                    android:text="@string/label_username"
                    android:textColor="@color/label_text"
                    android:textSize="@dimen/field_label_text_size"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_username"
                    android:layout_width="@dimen/field_width"
                    android:layout_height="@dimen/field_height"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/field_margin_top"
                    android:background="@drawable/shape_field_bg"
                    android:fontFamily="sans-serif-light"
                    android:gravity="center"
                    android:inputType="text"
                    android:letterSpacing="0.2"
                    android:paddingStart="@dimen/field_padding_horizontal"
                    android:paddingEnd="@dimen/field_padding_horizontal"
                    android:singleLine="true"
                    android:text="@string/field_username_value"
                    android:textColor="@color/text_black"
                    android:textSize="@dimen/field_text_size" />

                <!-- ── FIELD 2: First Name ────────────
                     Label id="38:38" y=437, fontWeight=800
                     Field id="38:20" y=454, text="John"
                     ─────────────────────────────────── -->
                <TextView
                    android:id="@+id/tv_label_first_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/field_label_margin_top"
                    android:alpha="0.75"
                    android:letterSpacing="0.2"
                    android:text="@string/label_first_name"
                    android:textColor="@color/label_text"
                    android:textSize="@dimen/field_label_text_size"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_first_name"
                    android:layout_width="@dimen/field_width"
                    android:layout_height="@dimen/field_height"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/field_margin_top"
                    android:background="@drawable/shape_field_bg"
                    android:fontFamily="sans-serif-light"
                    android:gravity="center"
                    android:inputType="textPersonName"
                    android:letterSpacing="0.2"
                    android:paddingStart="@dimen/field_padding_horizontal"
                    android:paddingEnd="@dimen/field_padding_horizontal"
                    android:singleLine="true"
                    android:text="@string/field_first_name_value"
                    android:textColor="@color/text_black"
                    android:textSize="@dimen/field_text_size" />

                <!-- ── FIELD 3: Middle Name ───────────
                     Label id="38:39" y=531, fontWeight=800
                     Field id="38:25" y=548, text="Middle"
                     ─────────────────────────────────── -->
                <TextView
                    android:id="@+id/tv_label_middle_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/field_label_margin_top"
                    android:alpha="0.75"
                    android:letterSpacing="0.2"
                    android:text="@string/label_middle_name"
                    android:textColor="@color/label_text"
                    android:textSize="@dimen/field_label_text_size"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_middle_name"
                    android:layout_width="@dimen/field_width"
                    android:layout_height="@dimen/field_height"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/field_margin_top"
                    android:background="@drawable/shape_field_bg"
                    android:fontFamily="sans-serif-light"
                    android:gravity="center"
                    android:inputType="textPersonName"
                    android:letterSpacing="0.2"
                    android:paddingStart="@dimen/field_padding_horizontal"
                    android:paddingEnd="@dimen/field_padding_horizontal"
                    android:singleLine="true"
                    android:text="@string/field_middle_name_value"
                    android:textColor="@color/text_black"
                    android:textSize="@dimen/field_text_size" />

                <!-- ── FIELD 4: Last Name ─────────────
                     Label id="38:40" y=625, fontWeight=800
                     Field id="38:35" y=642, text="Doe"
                     ─────────────────────────────────── -->
                <TextView
                    android:id="@+id/tv_label_last_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/field_label_margin_top"
                    android:alpha="0.75"
                    android:letterSpacing="0.2"
                    android:text="@string/label_last_name"
                    android:textColor="@color/label_text"
                    android:textSize="@dimen/field_label_text_size"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_last_name"
                    android:layout_width="@dimen/field_width"
                    android:layout_height="@dimen/field_height"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/field_margin_top"
                    android:background="@drawable/shape_field_bg"
                    android:fontFamily="sans-serif-light"
                    android:gravity="center"
                    android:inputType="textPersonName"
                    android:letterSpacing="0.2"
                    android:paddingStart="@dimen/field_padding_horizontal"
                    android:paddingEnd="@dimen/field_padding_horizontal"
                    android:singleLine="true"
                    android:text="@string/field_last_name_value"
                    android:textColor="@color/text_black"
                    android:textSize="@dimen/field_text_size" />

                <!-- ── FIELD 5: Email ─────────────────
                     Label id="38:41" y=719, fontWeight=800
                     Field id="38:30" y=736, text="johndoe@gmail.com"
                     ─────────────────────────────────── -->
                <TextView
                    android:id="@+id/tv_label_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/field_label_margin_top"
                    android:alpha="0.75"
                    android:letterSpacing="0.2"
                    android:text="@string/label_email"
                    android:textColor="@color/label_text"
                    android:textSize="@dimen/field_label_text_size"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_email"
                    android:layout_width="@dimen/field_width"
                    android:layout_height="@dimen/field_height"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/field_margin_top"
                    android:background="@drawable/shape_field_bg"
                    android:fontFamily="sans-serif-light"
                    android:gravity="center"
                    android:inputType="textEmailAddress"
                    android:letterSpacing="0.2"
                    android:paddingStart="@dimen/field_padding_horizontal"
                    android:paddingEnd="@dimen/field_padding_horizontal"
                    android:singleLine="true"
                    android:text="@string/field_email_value"
                    android:textColor="@color/text_black"
                    android:textSize="@dimen/field_text_size" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</FrameLayout>