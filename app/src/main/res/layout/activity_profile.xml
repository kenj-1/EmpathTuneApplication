<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_profile.xml
    Target  : Small Phone API 36 — 360 × 640 dp
    Root    : LinearLayout (vertical) per spec
    ─────────────────────────────────────────────────────────────────
    ALL IDs PRESERVED (ProfileActivity.kt binding):
      iv_menu               → ImageView  (click = finish())
    Display-only IDs kept for future presenter expansion:
      iv_profile_photo · tv_username_display · tv_empathy_status
      tv_label_username · et_username
      tv_label_first_name · et_first_name
      tv_label_middle_name · et_middle_name
      tv_label_last_name · et_last_name
      tv_label_email · et_email
    ─────────────────────────────────────────────────────────────────
    Visual notes (from Figma screenshot analysis):
      • White header: profile photo (circle, ~90dp), name, status,
        two small yellow circle buttons at top-right
      • Yellow→gray gradient card: starts below header, fills
        remaining height above the bottom nav, rounded 26dp corners
      • 5 label + pill-input field pairs inside the card
      • Bottom nav bar identical to Dashboard (create | home | profile)
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- ═══════════════════════════════════════════════════════
         HEADER — white section
         RelativeLayout needed: photo + text column + two
         top-right buttons need anchored/overlapping placement.
         Height: ~132dp matches Figma header region (y=0–234).
         ═══════════════════════════════════════════════════════ -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="132dp"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- ── Profile photo (Figma: image_9, x=22, y=87, 123×123dp)
             Circular dark background with white silhouette icon.
             Vertically centered in the header, aligned to start.    -->
        <ImageView
            android:id="@+id/iv_profile_photo"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"

            android:contentDescription="Profile photo"
            android:padding="14dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_profile_placeholder" />
<!--
android:background="@drawable/shape_profile_photo_bg"
-->
        <!-- ── Name + Empathy Status (Figma: "User" 32sp, "Empathy Status: Yearner" 12sp)
             Vertically centered, positioned to the right of the photo. -->
        <LinearLayout
            android:id="@+id/ll_name_block"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="14dp"
            android:layout_toEndOf="@id/iv_profile_photo"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_username_display"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.05"
                android:text="User"
                android:textColor="#000000"
                android:textSize="28sp" />

            <TextView
                android:id="@+id/tv_empathy_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.05"
                android:text="Empathy Status: Yearner"
                android:textColor="#000000"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- ── Logout button (Figma: Logout_Button, x=284, y=24, 34dp yellow circle)
             No ID needed — purely decorative in this version.
             Sits at top-right, slightly left of the menu button.    -->
        <ImageView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:layout_marginEnd="46dp"
            android:layout_marginTop="14dp"

            android:contentDescription="Back"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_nav_create" />
<!--android:background="@drawable/shape_profile_btn_bg"-->
        <!-- ── Menu button (Figma: Group_19, x=335, y=17, ~34dp yellow circle)
             ID: iv_menu — ProfileActivity.kt calls finish() on click.  -->
        <ImageView
            android:id="@+id/iv_menu"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:layout_marginEnd="6dp"
            android:layout_marginTop="14dp"

            android:clickable="true"
            android:contentDescription="Menu"
            android:focusable="true"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_profile_menu" />
<!--android:background="@drawable/shape_profile_btn_bg"-->


    </RelativeLayout>

    <!-- ═══════════════════════════════════════════════════════
         GRADIENT FORM CARD  (weight=1 fills remaining height)
         Figma: LogInBoard — #FEFE53→#BBBBBB gradient, 30dp radius
         The card fills the space between header and bottom nav.
         ScrollView is nested so the card background is always
         visible even when content is shorter than the screen.
         ═══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="6dp"

        android:orientation="vertical">
<!--android:background="@drawable/shape_profile_card"-->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="20dp"
                android:paddingBottom="24dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <!-- ═══════════════════════════════════════════
                     FIELD PATTERN (repeated 5 times):
                       • Bold centered label (75% opacity)
                       • Centered pill EditText
                     Figma: label fontSize=12sp ExtraBold
                            field h=34dp, cornerRadius=40dp
                     ═══════════════════════════════════════════ -->

                <!-- ── 1. USERNAME ─────────────────────────── -->
                <TextView
                    android:id="@+id/tv_label_username"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="4dp"
                    android:alpha="0.75"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="0.05"
                    android:text="Username"
                    android:textColor="#000000"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_username"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:layout_marginBottom="10dp"

                    android:fontFamily="sans-serif-light"
                    android:gravity="center"
                    android:inputType="text"
                    android:letterSpacing="0.05"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:singleLine="true"
                    android:text="User"
                    android:textColor="#000000"
                    android:textSize="11sp" />
                <!--android:background="@drawable/shape_profile_field"-->

                <!-- ── 2. FIRST NAME ───────────────────────── -->
                <TextView
                    android:id="@+id/tv_label_first_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="4dp"
                    android:alpha="0.75"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="0.05"
                    android:text="First Name"
                    android:textColor="#000000"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_first_name"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:layout_marginBottom="10dp"

                    android:fontFamily="sans-serif-light"
                    android:gravity="center"
                    android:inputType="textPersonName"
                    android:letterSpacing="0.05"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:singleLine="true"
                    android:text="John"
                    android:textColor="#000000"
                    android:textSize="11sp" />
<!--android:background="@drawable/shape_profile_field"-->
                <!-- ── 3. MIDDLE NAME ──────────────────────── -->
                <TextView
                    android:id="@+id/tv_label_middle_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="4dp"
                    android:alpha="0.75"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="0.05"
                    android:text="Middle Name"
                    android:textColor="#000000"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_middle_name"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:layout_marginBottom="10dp"

                    android:fontFamily="sans-serif-light"
                    android:gravity="center"
                    android:inputType="textPersonName"
                    android:letterSpacing="0.05"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:singleLine="true"
                    android:text="Middle"
                    android:textColor="#000000"
                    android:textSize="11sp" />
<!--android:background="@drawable/shape_profile_field"-->
                <!-- ── 4. LAST NAME ───────────────────────── -->
                <TextView
                    android:id="@+id/tv_label_last_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="4dp"
                    android:alpha="0.75"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="0.05"
                    android:text="Last Name"
                    android:textColor="#000000"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_last_name"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:layout_marginBottom="10dp"

                    android:fontFamily="sans-serif-light"
                    android:gravity="center"
                    android:inputType="textPersonName"
                    android:letterSpacing="0.05"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:singleLine="true"
                    android:text="Doe"
                    android:textColor="#000000"
                    android:textSize="11sp" />
                <!--android:background="@drawable/shape_profile_field"-->

                <!-- ── 5. EMAIL ───────────────────────────── -->
                <TextView
                    android:id="@+id/tv_label_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="4dp"
                    android:alpha="0.75"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="0.05"
                    android:text="Email"
                    android:textColor="#000000"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_email"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"

                    android:fontFamily="sans-serif-light"
                    android:gravity="center"
                    android:inputType="textEmailAddress"
                    android:letterSpacing="0.05"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:singleLine="true"
                    android:text="johndoe@gmail.com"
                    android:textColor="#000000"
                    android:textSize="11sp"/>
                <!--android:background="@drawable/shape_profile_field"-->

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════
         BOTTOM NAVIGATION BAR — identical to Dashboard
         Figma: ProfileNavigation — #E9EE67 bg, 3 icon slots.
         Profile slot is the active/highlighted item (right).
         These IDs are NOT referenced by ProfileActivity.kt,
         so they are visual-only — no code changes needed.
         ═══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:orientation="horizontal"
        android:background="@drawable/shape_bottom_nav"
        android:gravity="center_vertical">

        <!-- LEFT: create/add icon -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Create"
            android:focusable="true"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_nav_create" />

        <!-- CENTER: home icon on raised white circle -->
        <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">



            <ImageView
                android:id="@+id/iv_home_nav"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_centerInParent="true"
                android:contentDescription="Home"
                android:elevation="5dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_home" />

        </RelativeLayout>

        <!-- RIGHT: profile icon — active state (highlighted circle behind it) -->
        <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <!-- Raised circle indicates active tab -->
            <View
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_centerInParent="true"
                android:background="@drawable/shape_circle_white_nav"
                android:elevation="4dp" />

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_centerInParent="true"
                android:contentDescription="Profile"
                android:elevation="5dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_profile" />

        </RelativeLayout>

    </LinearLayout>

</LinearLayout>